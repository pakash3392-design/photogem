# Get this from https://replicate.com/account/api-tokens (free account, pay-per-use after that)
REPLICATE_API_TOKEN=

# Optional. The app defaults to black-forest-labs/flux-kontext-pro, Replicate's
# official photo-editing model -- no model-hunting or version hash needed.
# Only set this if you want to swap to a different model later.
# REPLICATE_MODEL_VERSION=owner/model-name
